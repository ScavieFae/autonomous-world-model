# Matrix bot configuration — copy to .env and fill in values
# NEVER commit .env to git (it's gitignored)

export MATRIX_HOMESERVER="http://your-server:8008"
export MATRIX_BOT_USER="@conductor"
export MATRIX_BOT_PASS="your-bot-password"
export MATRIX_SERVER_NAME="your.server.name"

# Room IDs (from Element → Room Settings → Advanced)
export MATRIX_CONDUCTOR_ROOM="!roomid:your.server.name"
export MATRIX_EXPERIMENT_ROOM="!roomid:your.server.name"
export MATRIX_ESCALATION_ROOM="!roomid:your.server.name"

# Comma-separated Matrix user IDs authorized to send commands
export MATRIX_AUTHORIZED_USERS="@mattie:your.server.name"
